# Leave unset to use relative /api (recommended: proxy in vite.config to backend).
# When using IP or host, include the API port. Use http for local/LAN (https causes ERR_SSL_PROTOCOL_ERROR):
# VITE_API_URL=/api
# VITE_API_URL=http://192.168.1.2:3000/api

# Local LLM (OpenAI-compatible: Ollama on http://127.0.0.1:11434, etc.)
# `npm run dev` at repo root runs a quick GET /v1/models check when these are set.
# VITE_LU_API_URL=http://127.0.0.1:11434
# VITE_LU_MODEL=phi3:mini
# VITE_LU_API_KEY=
# Optional: global defaults for Help chat & other streamChat callers (OpenAI-style API)
# VITE_LU_MAX_TOKENS=800
# VITE_LU_TEMPERATURE=0.45
# (File editor override: lower temp + max 520 in code; raise tokens here for longer help replies elsewhere.)

# Optional: document conversion (Vert)
VITE_VERT_URL=http://localhost:3003

# Production self-host: canonical public origin for share links (Tryout, no trailing slash).
# Set this so copied links never use a temporary tunnel host or wrong browser origin.
# VITE_PUBLIC_SITE_URL=https://nexacore1.duckdns.org

# Optional: enable debug toasts
# VITE_DEBUG_MODE=true
