# Database (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/yourdrive

# JWT (required) - generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=generate-this-with-openssl-rand-base64-32
JWT_REFRESH_SECRET=generate-this-with-openssl-rand-base64-32

# S3-compatible storage (e.g. Backblaze B2)
B2_KEY_ID=xxx
B2_APPLICATION_KEY=xxx
B2_BUCKET_NAME=xxx
B2_ENDPOINT=xxx
B2_REGION=xxx

BCRYPT_ROUNDS=12
NODE_ENV=development

# URLs (required for CORS and callbacks)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# Server (optional)
PORT=3000
# HOST=0.0.0.0
# Use HOST=127.0.0.1 to bind only to localhost

# VERT_URL=https://convert.yourdomain.com

RP_NAME=YourDrive
RP_ID=localhost
RP_ORIGIN=http://localhost:5173
BACKEND_DOMAIN=localhost

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# OAuth callback URLs (use same as FRONTEND_URL / BACKEND_URL above)